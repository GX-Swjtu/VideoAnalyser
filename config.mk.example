# ============================================
# VideoAnalyser 本地构建配置
# ============================================
# 使用说明：
#   1. 将本文件复制为 config.mk
#   2. 根据你的本地环境修改下面的路径
#   3. config.mk 已被 .gitignore 忽略，不会提交到仓库
# ============================================

# ---- Windows 配置示例 ----
# Qt 安装路径（MinGW 版本）
# QT_DIR       = E:/Qt/6.8.3/mingw_64

# MinGW 工具链路径
# MINGW_DIR    = E:/Qt/Tools/mingw1310_64

# CMake 可执行文件（如果已加入 PATH 可不设置）
# CMAKE        = E:/Qt/Tools/CMake_64/bin/cmake.exe

# vcpkg 根目录
# VCPKG_ROOT   = C:/vcpkgCache/vcpkg

# vcpkg triplet（MinGW 用 x64-mingw-dynamic，MSVC 用 x64-windows）
# VCPKG_TRIPLET = x64-mingw-dynamic

# ---- Linux 配置示例 ----
# vcpkg 根目录（如果使用系统包管理器安装 FFmpeg 则可不设置）
# VCPKG_ROOT   = $(HOME)/vcpkg
# VCPKG_TRIPLET = x64-linux
