{
    "version": 6,
    "$comment": "将此文件复制为 CMakeUserPresets.json，然后将下面的路径替换为你本机的实际路径。该文件已被 .gitignore 忽略，不会提交到仓库。",
    "configurePresets": [
        {
            "name": "local-debug",
            "displayName": "Local Debug",
            "inherits": "windows-debug",
            "binaryDir": "${sourceDir}/build/Debug",
            "cacheVariables": {
                "$comment-CMAKE_PREFIX_PATH": "Qt 安装路径，例如 C:/Qt/6.8.3/mingw_64",
                "CMAKE_PREFIX_PATH": "<你的Qt路径>/6.x.x/mingw_64",
                "$comment-CMAKE_CXX_COMPILER": "MinGW g++ 路径",
                "CMAKE_CXX_COMPILER": "<你的MinGW路径>/bin/g++.exe",
                "CMAKE_C_COMPILER": "<你的MinGW路径>/bin/gcc.exe",
                "$comment-CMAKE_MAKE_PROGRAM": "Ninja 路径（如果不在 PATH 中需指定）",
                "CMAKE_MAKE_PROGRAM": "<你的Ninja路径>/ninja.exe",
                "$comment-CMAKE_TOOLCHAIN_FILE": "vcpkg 工具链路径",
                "CMAKE_TOOLCHAIN_FILE": "<你的vcpkg路径>/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "local-release",
            "displayName": "Local Release",
            "inherits": "windows-release",
            "binaryDir": "${sourceDir}/build/Release",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "<你的Qt路径>/6.x.x/mingw_64",
                "CMAKE_CXX_COMPILER": "<你的MinGW路径>/bin/g++.exe",
                "CMAKE_C_COMPILER": "<你的MinGW路径>/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "<你的Ninja路径>/ninja.exe",
                "CMAKE_TOOLCHAIN_FILE": "<你的vcpkg路径>/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "local-asan",
            "displayName": "Local ASan+UBSan",
            "inherits": "windows-asan",
            "binaryDir": "${sourceDir}/build/ASan",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "<你的Qt路径>/6.x.x/mingw_64",
                "CMAKE_CXX_COMPILER": "<你的MinGW路径>/bin/g++.exe",
                "CMAKE_C_COMPILER": "<你的MinGW路径>/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "<你的Ninja路径>/ninja.exe",
                "CMAKE_TOOLCHAIN_FILE": "<你的vcpkg路径>/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "local-static",
            "displayName": "Local Static (Green)",
            "description": "全静态构建，生成单文件绿色版。Qt 通过 vcpkg 自动安装，无需设置 CMAKE_PREFIX_PATH",
            "inherits": "windows-static",
            "binaryDir": "${sourceDir}/build/Static",
            "environment": {
                "$comment": "vcpkg 编译器检测需要 MinGW 在 PATH 中",
                "PATH": "<你的MinGW路径>/bin;$penv{PATH}"
            },
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "<你的MinGW路径>/bin/g++.exe",
                "CMAKE_C_COMPILER": "<你的MinGW路径>/bin/gcc.exe",
                "CMAKE_MAKE_PROGRAM": "<你的Ninja路径>/ninja.exe",
                "CMAKE_TOOLCHAIN_FILE": "<你的vcpkg路径>/scripts/buildsystems/vcpkg.cmake"
            }
        }
    ],
    "buildPresets": [
        { "name": "local-debug",   "configurePreset": "local-debug" },
        { "name": "local-release", "configurePreset": "local-release" },
        { "name": "local-asan",    "configurePreset": "local-asan" },
        { "name": "local-static",  "configurePreset": "local-static" }
    ],
    "testPresets": [
        {
            "name": "local-debug",
            "configurePreset": "local-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "local-asan",
            "configurePreset": "local-asan",
            "output": { "outputOnFailure": true }
        }
    ]
}
