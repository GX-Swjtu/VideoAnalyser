{
    "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
    "name": "videoanalyser",
    "version-string": "0.1",
    "description": "Video Analyser - Qt/FFmpeg 视频分析工具",
    "dependencies": [
        {
            "name": "ffmpeg",
            "features": [
                "avcodec",
                "avdevice",
                "avfilter",
                "avformat",
                "swresample",
                "swscale",

                "dav1d",
                "vpx",
                "opus",
                "vorbis",
                "theora",
                "openh264",
                "openjpeg",
                "mp3lame",

                "bzip2",
                "zlib",
                "iconv",
                "xml2"
            ]
        },
        "gtest"
    ],
    "features": {
        "static-qt": {
            "description": "通过 vcpkg 安装 Qt（用于全静态构建，生成单文件绿色版）",
            "dependencies": [
                {
                    "name": "qtbase",
                    "default-features": false,
                    "features": ["concurrent", "widgets", "network", "png", "jpeg", "freetype"]
                },
                "qtcharts",
                "qttools"
            ]
        }
    }
}
